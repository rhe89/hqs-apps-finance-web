# finance-web local development environment
# Copy this to .env.local and fill in values.
# .env.local is git-ignored and never committed.

# URL of the Finance API (running locally or in Docker)
FINANCE_API_BASE_URL=https://localhost:7200

# mTLS client cert for authenticating with the Finance API.
# Leave blank to skip mTLS (only works if the API has DisableMtls=true in appsettings.Development.json).
FINANCE_API_CLIENT_CERT_PATH=
FINANCE_API_CLIENT_KEY_PATH=
FINANCE_API_CA_CERT_PATH=

# SQLite database path for favorites (auto-created on first run)
FINANCE_WEB_DB_PATH=./data/finance-web.db
